# Copia este archivo a .env y completa las claves.
# .env NO se versiona (ver .gitignore).

# --- LLM (OpenCode Go) ---
# La API key de OpenCode se lee automáticamente de ~/.local/share/opencode/auth.json
# (la misma cuenta que usas en opencode). Si prefieres definir-la aquí, descomenta:
# OPENCODE_API_KEY=
#
# Endpoint y modelo (OpenCode Go, OpenAI-compatible):
OPENCODE_BASE_URL=https://opencode.ai/zen/go/v1
# Modelo para generación de política (Capa 3): razonamiento, ~30s, calidad alta.
OPENCODE_MODEL=glm-5.2
# Modelo para tareas JSON estructuradas (propose_weights.py): más rápido y limpio para JSON.
# No se usa en generación de política. Pesos ya congelados con glm-5.2 — no se regeneran.
OPENCODE_MODEL_JSON=deepseek-v4-flash
# User-Agent requerido por Cloudflare (no cambiar):
OPENCODE_USER_AGENT=opencode/1.15.7

# --- Retrieval semántico (Voyage AI) ---
# Clave de Voyage AI para embeddings + reranking (https://dash.voyageai.com, capa gratuita)
VOYAGE_API_KEY=
VOYAGE_EMBED_MODEL=voyage-3
VOYAGE_RERANK_MODEL=rerank-2

# Umbral de abstención del retriever (0-1). Si ningún chunk supera esto, el sistema se abstiene.
RETRIEVAL_THRESHOLD=0.35
